<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/
    
    # If the request is not a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all requests to index.php
    RewriteRule ^(.*)$ index.php?$1 [QSA,L]
</IfModule>
